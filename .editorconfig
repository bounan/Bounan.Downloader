root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# noinspection EditorConfigKeyCorrectness
[*.cs]
# Formatting
indent_size = 4
csharp_new_line_before_open_brace = all
csharp_new_line_between_query_expression_clauses = true

dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_space_between_collection_initializer_braces = true

# Space after commas (including collection initializers)
csharp_space_after_comma = true

# Prefer file-scoped namespaces in modern code; net48 projects can still compile with newer language versions
csharp_style_namespace_declarations = file_scoped:warning

# Usings
csharp_using_directive_placement = outside_namespace:warning

# var usage: prefer explicit unless obvious
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = true:warning
csharp_style_var_elsewhere = true:warning

# Expression-bodied members: limited (readability)
csharp_style_expression_bodied_methods = false:warning
csharp_style_expression_bodied_properties = true:warning

# Pattern matching / modern readability
csharp_style_prefer_pattern_matching = true:warning
csharp_style_prefer_not_pattern = true:warning

# Null checks
dotnet_style_coalesce_expression = true:warning
dotnet_style_null_propagation = true:warning

# Qualification (avoid 'this.' noise)
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning
dotnet_diagnostic.SA1101.severity = none
dotnet_diagnostic.SX1101.severity = warning

# Disable/setup particular rules
dotnet_code_quality.CA1822.api_surface = private # Only private members should be flagged for static
dotnet_diagnostic.CA2007.severity = none # Use 'ConfigureAwait'
dotnet_diagnostic.SA0001.severity = none # XML comment analysis should be disabled for generated code
dotnet_diagnostic.SA1134.severity = none # Attributes should not share line
dotnet_diagnostic.SA1204.severity = none # Static elements should appear before instance elements
dotnet_diagnostic.SA1600.severity = none # Elements should be documented
dotnet_diagnostic.SA1601.severity = none # Partial elements should be documented
dotnet_diagnostic.SA1633.severity = none # File should have header
dotnet_diagnostic.SA1652.severity = none # Enable XML documentation output

# To fix
dotnet_diagnostic.SA1404.severity = none # Code analysis suppression should have justification TODO: review existing suppressions and add justifications where appropriate
